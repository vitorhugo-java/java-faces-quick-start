# ─── Database ────────────────────────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/facesapp?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=facesapp_user
DB_PASSWORD=change_me_strong_password
DB_POOL_SIZE=10

# ─── Application ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080/facesapp
APP_SECRET_KEY=change_me_64_char_secret_key_for_tokens_here_1234567890abcdef

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=no-reply@yourdomain.com
MAIL_STARTTLS_ENABLE=true

# ─── Email Verification ───────────────────────────────────────────────────────
# Set to "true" to require users to verify their e-mail within 24 h before login.
# Unverified accounts older than 24 h are automatically removed at 03:00 daily.
EMAIL_VERIFICATION_REQUIRED=true

# ─── Cleanup Scheduler ───────────────────────────────────────────────────────
# Cron expression for the unverified-account cleanup job (default: every day at 03:00)
CLEANUP_CRON=0 0 3 * * *
