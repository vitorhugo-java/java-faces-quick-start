<?xml version="1.0" encoding="UTF-8"?>
<!--
    Isolates the WAR's bundled Hibernate from WildFly's own copy,
    preventing ClassCastExceptions and version conflicts.
-->
<jboss-deployment-structure>
    <deployment>
        <exclusions>
            <!-- Use the WAR's bundled Hibernate, not WildFly's module -->
            <module name="org.hibernate.orm.main"/>
        </exclusions>
        <dependencies>
            <!-- WildFly's Jakarta EE APIs are still provided -->
            <module name="jakarta.faces.api" export="true"/>
        </dependencies>
    </deployment>
</jboss-deployment-structure>
