<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.1"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd">

    <!--
        RESOURCE_LOCAL persistence unit.
        JDBC connection details are supplied at runtime by UserRepository
        using values read from the .env file via EnvConfig.
    -->
    <persistence-unit name="FacesAppPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.example.facesapp.model.User</class>
        <class>com.example.facesapp.model.VerificationToken</class>
        <class>com.example.facesapp.model.PasswordResetToken</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.jdbc.driver"
                      value="com.mysql.cj.jdbc.Driver"/>
            <!-- url / user / password are overridden at runtime from .env -->

            <property name="hibernate.dialect"
                      value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto"
                      value="validate"/>
            <property name="hibernate.show_sql"
                      value="false"/>
            <property name="hibernate.format_sql"
                      value="false"/>
            <property name="hibernate.connection.pool_size"
                      value="5"/>
        </properties>

    </persistence-unit>

</persistence>
